{
  "expo": {
    "name": "ScaleGram",
    "slug": "ScaleGram",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "scalegram",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/icon.png"
    },
    "android": {
      "softwareKeyboardLayoutMode": "resize",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.ScaleGram",
      "permissions": [
        "CAMERA",
        "RECORD_AUDIO",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "cameraPermission": "Izinkan ScaleGram mengakses kamera Anda untuk membuat Story."
        }
      ],
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 76
        }
      ],
      "expo-font",
      "expo-secure-store",
      "expo-video",
      [
        "expo-media-library",
        {
          "photosPermission": "Izinkan ScaleGram mengakses foto di galeri Anda.",
          "savePhotosPermission": "Izinkan ScaleGram menyimpan foto ke galeri Anda.",
          "videosPermission": "Izinkan ScaleGram mengakses video di galeri Anda.",
          "saveVideosPermission": "Izinkan ScaleGram menyimpan video ke galeri Anda.",
          "audioPermission": "Izinkan ScaleGram mengakses audio untuk kebutuhan media.",
          "saveAudioPermission": "Izinkan ScaleGram menyimpan file audio Anda."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}